#!/bin/sh

# Show the IPv4 address used for normal outbound traffic. Querying a
# public route target avoids hard-coding an interface name, so this keeps
# working across Wi-Fi, Ethernet, VPN, and container-heavy setups.
ip_address=$(ip route get 1.1.1.1 2>/dev/null | awk '
  {
    for (i = 1; i <= NF; i++) {
      if ($i == "src" && (i + 1) <= NF) {
        print $(i + 1)
        exit
      }
    }
  }
')
rc=$?

if [ "$rc" -ne 0 ] || [ -z "$ip_address" ]; then
  ip_address=$(hostname -I 2>/dev/null | awk '{ print $1 }')
fi

if [ -n "$ip_address" ]; then
  printf '%s' "$ip_address"
else
  printf '%s' '-'
fi
