#!/bin/sh

dir=$1

[ -d "$dir" ] || exit 0

branch=$(git -C "$dir" symbolic-ref --quiet --short HEAD 2>/dev/null)
rc=$?

if [ "$rc" -ne 0 ]; then
  branch=$(git -C "$dir" rev-parse --short HEAD 2>/dev/null)
  rc=$?
fi

[ "$rc" -eq 0 ] || exit 0
[ -n "$branch" ] || exit 0

printf ' | git:%s' "$branch"
